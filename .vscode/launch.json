{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DeepSeek TUI Extension",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "build:extension",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/extensions/vscode/out/**/*.js"
      ],
      "env": {
        "DEEPSEEK_API_KEY": "${input:deepseekApiKey}"
      }
    }
  ],
  "inputs": [
    {
      "type": "promptString",
      "id": "deepseekApiKey",
      "description": "Enter your DeepSeek API Key",
      "password": true
    }
  ]
}
